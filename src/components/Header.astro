  { href: 'how-it-works.html', label: 'How It Works', key: 'how' },
  { href: 'insights.html', label: 'Insights', key: 'insights' },
  { href: 'videos.html', label: 'Videos', key: 'videos' },
  { href: 'contact.html', label: 'Contact', key: 'contact' },
