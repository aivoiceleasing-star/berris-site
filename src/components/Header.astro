---
<header class="bg-base border-b border-ink/10">
  <nav class="mx-auto max-w-content px-6 h-[136px] flex items-center justify-between">
    <a href="index.html" class="flex items-center">
      <img src="/berris-logo.webp" alt="Berris Law Firm" class="w-auto" style="height:124px" />
    </a>
    <div class="hidden lg:flex items-center gap-9 text-[15px]">
      {items.map((it) => (
        <a href={it.href} class={active === it.key ? 'text-navy font-medium' : 'text-stone hover:text-navy transition-colors'}>{it.label}</a>
      ))}
    </div>
    <div class="nav-actions-desktop" style="position:relative;display:flex;align-items:center;">
      <a href="contact.html" class="inline-flex items-center rounded-full bg-blue px-5 py-2.5 text-[15px] font-medium text-white transition-transform active:scale-[.98] hover:bg-navy">
        Book free consult
      </a>
      <div style="position:absolute;top:calc(100% + 6px);left:50%;transform:translateX(-50%);display:flex;align-items:center;gap:6px;">
        <a class="soc" href="https://www.instagram.com/berrislawfirm/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" title="Instagram"><svg viewBox="0 0 24 24" aria-hidden="true"><path d={ig} /></svg></a>
        <a class="soc" href="#" aria-label="Facebook" title="Facebook"><svg viewBox="0 0 24 24" aria-hidden="true"><path d={fb} /></svg></a>
        <a class="soc" href="#" aria-label="LinkedIn" title="LinkedIn"><svg viewBox="0 0 24 24" aria-hidden="true"><path d={li} /></svg></a>
      </div>
    </div>
    <button class="hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu" onclick="var m=document.getElementById('mobile-menu');var o=m.classList.toggle('open');this.setAttribute('aria-expanded',String(o));this.setAttribute('aria-label',o?'Close menu':'Open menu');"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/></svg></button>
  </nav>
  <nav id="mobile-menu" class="mobile-menu" aria-label="Mobile navigation">
    {items.map((it) => (
      <a href={it.href} aria-current={active === it.key ? 'page' : undefined}>{it.label}</a>
    ))}
    <a href="contact.html" class="mm-cta">Book free consult</a>
    <div class="mm-social">
      <a class="soc" href="https://www.instagram.com/berrislawfirm/" target="_blank" rel="noopener noreferrer" aria-label="Instagram"><svg viewBox="0 0 24 24" aria-hidden="true"><path d={ig} /></svg></a>
      <a class="soc" href="#" aria-label="Facebook"><svg viewBox="0 0 24 24" aria-hidden="true"><path d={fb} /></svg></a>
      <a class="soc" href="#" aria-label="LinkedIn"><svg viewBox="0 0 24 24" aria-hidden="true"><path d={li} /></svg></a>
    </div>
  </nav>
</header>
