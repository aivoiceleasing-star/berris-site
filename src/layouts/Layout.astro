---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { title, description = '', active = '', headExtra = '' } = Astro.props;

// Reveal-on-scroll + the real consult-form wiring (POST to agency-portal lead
// capture -> lead stored + Ari emailed, then reveal the prefilled Cal.com button).
// Self-guards with `if (!form) return`, so it is inert on pages without the form.
const SITE_SCRIPT = `
(function () {
  var els = document.querySelectorAll('.reveal');
  function revealAll() { els.forEach(function (el) { el.classList.add('in'); }); }
  var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduce || !('IntersectionObserver' in window)) { revealAll(); return; }
  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
    });
  }, { threshold: 0.05, rootMargin: '0px 0px -8% 0px' });
  els.forEach(function (el) { io.observe(el); });
  setTimeout(revealAll, 1600);
})();

(function () {
  var form = document.getElementById('consultForm');
  if (!form) return;
  var ENDPOINT = 'https://agency-portal-eta.vercel.app/api/leads/capture';
  var CAL = 'https://cal.com/berriswillsandtrusts.com/free-consultation';
  form.addEventListener('submit', function (ev) {
    ev.preventDefault();
    var nameV = document.getElementById('name').value.trim();
    var emailV = document.getElementById('email').value.trim();
    var phoneV = document.getElementById('phone').value.trim();
    var err = document.getElementById('formError');
    var ok = document.getElementById('formSuccess');
    var btn = document.getElementById('submitBtn');
    var validEmail = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(emailV);
    if (!nameV || !validEmail) {
      err.textContent = 'Please enter your name and a valid email.';
      err.classList.remove('hidden'); ok.classList.add('hidden'); return;
    }
    err.classList.add('hidden');
    var label = btn.textContent; btn.disabled = true; btn.textContent = 'Sending' + String.fromCharCode(8230);
    fetch(ENDPOINT, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ client_id: 6, name: nameV, email: emailV, phone: phoneV, source: 'website-contact-form' })
    })
    .then(function (r) { return r.json(); })
    .then(function (res) {
      if (!res || res.error) throw new Error((res && res.error) || 'failed');
      var cal = document.getElementById('calBtn');
      if (cal) cal.href = CAL + '?name=' + encodeURIComponent(nameV) + '&email=' + encodeURIComponent(emailV);
      var msg = ok.querySelector('p');
      if (msg) msg.textContent = 'Thanks, ' + nameV + '! We will reach out within one business day to schedule your free consult.';
      ok.classList.remove('hidden');
      Array.prototype.forEach.call(ok.parentElement.children, function (c) { if (c.id !== 'formSuccess') c.style.display = 'none'; });
    })
    .catch(function () {
      err.textContent = 'Sorry, something went wrong. Please email info@berriswillsandtrusts.com and we will get you scheduled.';
      err.classList.remove('hidden');
    })
    .finally(function () { btn.disabled = false; btn.textContent = label; });
  });
})();
`;
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  {headExtra && <Fragment set:html={headExtra} />}
</head>
<body class="bg-base text-ink font-sans text-[17px] leading-relaxed antialiased">
  <a href="#top" class="skip-link">Skip to main content</a>
  <Header active={active} />
  <slot />
  <Footer />
  <script is:inline set:html={SITE_SCRIPT} />
</body>
</html>
